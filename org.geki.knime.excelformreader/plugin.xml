<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
  <extension point="org.knime.workbench.repository.categories">
    <category
      path="/"
      level-id="community-extensions"
      name="Community Extensions"
      icon="icons/excelformreader.png"
      after="org.knime.base"/>
    <category
      path="/community-extensions"
      level-id="io"
      name="IO"
      icon="icons/excelformreader.png"
      after=""/>
  </extension>

  <extension point="org.knime.workbench.repository.nodes">
    <node
      factory-class="org.geki.knime.excelformreader.ExcelFormReaderNodeFactory"
      category-path="/community-extensions/io"
      after=""/>
  </extension>
</plugin>
